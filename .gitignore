# Local env (optional; keep out of repo if you add secrets here)
.env
.env.*
!.env.example

# Backup configs
openclaw.json.bak*

# Secrets / device / TLS material
identity/
devices/
ssl/

# Runtime logs and app state
logs/
# Per-workspace OpenClaw UI/state (regenerated at runtime)
**/.openclaw/workspace-state.json
# memory/ — 暂随 Git 跟踪日记忆；若含敏感信息可恢复忽略
media/
delivery-queue/
exec-approvals.json
update-check.json

# Agent conversation transcripts
agents/**/sessions/
subagents/

# Cron execution logs (runtime)
cron/runs/
cron/jobs.json.bak

# WeChat Work runtime maps (regenerated)
wecom/

# Dependencies and Python
**/node_modules/
__pycache__/
*.py[cod]
.venv/
venv/

# OS
.DS_Store

# Stock system generated artifacts
workspace/stock_system/data/
workspace/stock_system/logs/
workspace/stock_system/reports/
workspace/stock_system/pids/
workspace/stock_system/*.txt
!workspace/stock_system/requirements.txt
workspace/stock_system/*.log
workspace/stock_system/predictions.db
workspace/stock_system/config/calibration_overrides.json

plugin-runtime-deps/

*.tmp
