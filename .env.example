# Copy to .env in this directory (~/.openclaw/.env) — file is gitignored.
# Required after openclaw.json uses env SecretRefs (see SETUP.md §1.4.1).
#
# ONEAPI_API_KEY=          # models.providers.oneapi (OneAPI / OpenAI-compatible)
# GATEWAY_AUTH_TOKEN=      # gateway.auth.token (Control UI / API)
# WECOM_BOT_SECRET=        # channels.wecom.secret
#
# Optional:
# OPENCLAW_HOME=
# OLLAMA_API_KEY=
# STOCK_SYSTEM_ROOT=
# OPENCLAW_STOCK_AGENT_ID=main
# OPENCLAW_AGENT_LOCAL=1
# OPENCLAW_AGENT_TIMEOUT=600
# STOCK_OPENCLAW_CACHE_SEC=90

ONEAPI_API_KEY=
GATEWAY_AUTH_TOKEN=
WECOM_BOT_SECRET=
